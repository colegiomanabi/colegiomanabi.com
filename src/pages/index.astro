---
import Layout from "../layouts/Layout.astro";
import ContactForm from "../components/ContactForm.astro";
import { Icon } from "astro-icon/components";

const pilares = [
  { icon: "lucide:star", titulo: "Liderazgo Personal", desc: "Desarrollamos en cada alumno la confianza y la visión para guiar con propósito." },
  { icon: "lucide:heart", titulo: "Empatía", desc: "Fomentamos la comprensión y el respeto hacia los demás como base de la convivencia." },
  { icon: "lucide:shield", titulo: "Responsabilidad", desc: "Enseñamos a nuestros alumnos a asumir sus compromisos con integridad." },
  { icon: "lucide:book-open", titulo: "Aprendizaje con Propósito", desc: "Cada experiencia educativa está diseñada para tener un impacto real en la vida del alumno." },
];

const niveles = [
  {
    nombre: "Preescolar",
    edad: "3 – 6 años",
    img: "/preschool.webp",
    desc: "Despertando la curiosidad. Estimulamos el desarrollo a través del juego, la exploración y el descubrimiento.",
    puntos: ["Iniciación a la lectoescritura", "Inglés desde el primer día", "Desarrollo socioemocional", "Actividades motrices y deportivas"],
  },
  {
    nombre: "Primaria",
    edad: "6 – 12 años",
    img: "/school.webp",
    desc: "Un programa académico de alto nivel que combina excelencia, valores y el cuidado que tu hijo merece.",
    puntos: ["Ciencias, tecnología y matemáticas", "Programa de inglés", "Formación en valores y liderazgo", "Artes y expresión"],
  },
];

const oferta = [
  { icon: "lucide:message-circle", titulo: "Programa de inglés", desc: "Integración del idioma desde los primeros años para una formación bilingüe sólida." },
  { icon: "lucide:microscope", titulo: "Ciencias, tecnología y matemáticas", desc: "Espacios equipados para la experimentación y el aprendizaje práctico de las ciencias naturales." },
  { icon: "lucide:palette", titulo: "Artes y Expresión", desc: "Iniciación musical, canto coral y expresión artística como herramientas de desarrollo cognitivo y emocional." },
  { icon: "lucide:dumbbell", titulo: "Educación Física", desc: "Actividades deportivas y motrices que promueven la salud, el trabajo en equipo y la disciplina." },
  { icon: "lucide:users", titulo: "Formación en Valores", desc: "Programa de desarrollo humano que cultiva la empatía, el liderazgo y la responsabilidad social." },
  { icon: "lucide:laptop", titulo: "Herramientas digitales", desc: "Integración de tecnología para el aprendizaje del siglo XXI desde los primeros años." },
];

const instalaciones = [
  "Aulas modernas y bien iluminadas",
  "Laboratorio de ciencias equipado",
  "Centro de cómputo con tecnología actualizada",
  "Biblioteca y sala de lectura",
  "Cancha deportiva multiusos",
  "Zona de juegos para preescolar",
  "Comedor con servicio de alimentos saludables",
  "Áreas verdes y jardines",
  "Estacionamiento amplio para padres de familia",
];

const pasos = [
  { n: "01", titulo: "Contacto Inicial", desc: "Comunícate con nosotros por teléfono, correo o el formulario de contacto para solicitar información." },
  { n: "02", titulo: "Visita al Colegio", desc: "Agenda una visita guiada para conocer nuestras instalaciones, metodología y el equipo docente." },
  { n: "03", titulo: "Entrega de Documentos", desc: "Entrega la documentación requerida para iniciar el proceso de admisión de tu hijo." },
  { n: "04", titulo: "Inscripción", desc: "Completa el proceso de inscripción y da la bienvenida a tu hijo a la comunidad Manabi." },
];

const documentos = [
  { icon: "lucide:file-text", label: "Acta de nacimiento", nota: "Original y copia" },
  { icon: "lucide:id-card", label: "CURP del alumno", nota: "Impresión actualizada" },
  { icon: "lucide:clipboard-list", label: "Boleta de calificaciones", nota: "Del ciclo anterior (primaria)" },
  { icon: "lucide:syringe", label: "Cartilla de vacunación", nota: "Actualizada" },
  { icon: "lucide:house", label: "Comprobante de domicilio", nota: "Reciente" },
  { icon: "lucide:user-round", label: "Identificación oficial", nota: "Del padre o tutor" },
];
---

<Layout>
  <!-- Hero -->
  <section id="inicio" class="relative flex min-h-screen items-center overflow-hidden bg-brand-blue text-white">
    <img src="/manabi-hero.webp" alt="Alumnos de Colegio Manabi" class="absolute inset-0 h-full w-full object-cover object-[75%_20%]" />
    <div class="absolute inset-0 bg-gradient-to-r from-brand-blue from-30% via-brand-blue/78 via-58% to-transparent"></div>

    <div class="relative mx-auto mt-32 w-full max-w-7xl px-5 lg:px-8">
      <h1 class="max-w-3xl font-display text-4xl font-extrabold leading-tight sm:text-5xl lg:text-6xl">
        Donde el aprendizaje<br /><span class="text-brand-gold">tiene propósito</span>
      </h1>

      <p class="mt-6 max-w-xl text-base leading-relaxed text-white/70 lg:text-lg">
        Formamos niñas y niños con liderazgo, empatía y responsabilidad. Una educación integral para los líderes del mañana.
      </p>

      <div class="mt-9 flex flex-col gap-3 sm:flex-row">
        <a href="#contacto" class="rounded-full bg-brand-gold px-7 py-3.5 text-center text-sm font-bold text-brand-blue transition-all hover:brightness-105 active:scale-95">
          Agenda una Visita
        </a>
        <a href="#nosotros" class="rounded-full bg-white/10 px-7 py-3.5 text-center text-sm font-bold text-white ring-1 ring-white/20 transition-all hover:bg-white/20">
          Conoce el Colegio
        </a>
      </div>
    </div>
  </section>

  <!-- Nosotros -->
  <section id="nosotros" class="bg-white py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-20">
        <div class="relative">
          <div class="absolute -left-4 -top-4 h-full w-full rounded-3xl border-2 border-brand-gold"></div>
          <div class="relative">
            <img src="/us.webp" alt="Maestra leyendo un cuento a un grupo de alumnos de Colegio Manabi" class="aspect-square h-full w-full rounded-3xl object-cover shadow-2xl" />
            <div class="absolute -bottom-5 left-5 right-5 rounded-xl bg-brand-blue p-5 shadow-xl sm:-right-5 sm:left-8">
              <p class="font-display text-lg font-bold leading-snug text-white">«Formamos líderes con corazón, listos para la vida.»</p>
              <p class="mt-1 text-sm font-medium text-brand-gold">— Colegio Manabi</p>
            </div>
          </div>
        </div>

        <div>
          <span class="text-sm font-bold uppercase tracking-widest text-brand-gold">Quiénes Somos</span>
          <h2 class="mt-2 font-display text-3xl font-extrabold leading-tight text-brand-blue lg:text-4xl">Una nueva forma de entender la educación</h2>
          <p class="mt-5 leading-relaxed text-slate-600">
            Colegio Manabi nace de la convicción de que cada niño tiene un potencial único que merece ser descubierto y cultivado. Nuestro nombre proviene del japonés <em>学び (manabi)</em>, que significa aprendizaje — una filosofía que guía cada decisión pedagógica que tomamos.
          </p>
          <p class="mt-4 leading-relaxed text-slate-600">
            Ofrecemos educación de preescolar y primaria con grupos reducidos, maestros comprometidos y un modelo educativo centrado en el desarrollo integral: académico, emocional y humano.
          </p>

          <div class="mt-8 grid gap-4 sm:grid-cols-2">
            {pilares.map((p) => (
              <div class="flex gap-3 rounded-xl border border-slate-100 bg-slate-50 p-4">
                <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg bg-brand-blue text-white">
                  <Icon name={p.icon} class="h-5 w-5" />
                </div>
                <div>
                  <h3 class="font-display text-sm font-bold text-brand-blue">{p.titulo}</h3>
                  <p class="mt-1 text-sm leading-relaxed text-slate-600">{p.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Niveles -->
  <section id="niveles" class="bg-slate-50 py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="font-display text-3xl font-extrabold text-brand-blue lg:text-4xl">Nuestros Niveles Educativos</h2>
      </div>

      <div class="mt-16 space-y-14 lg:space-y-24">
        {niveles.map((n, i) => (
          <div class="grid items-center gap-8 lg:grid-cols-2 lg:gap-16">
            <div class={`overflow-hidden rounded-3xl shadow-xl ${i % 2 ? "lg:order-2" : ""}`}>
              <img src={n.img} alt={`Alumnos de ${n.nombre} en Colegio Manabi`} class="aspect-[4/3] h-full w-full object-cover" />
            </div>

            <div class={i % 2 ? "lg:order-1" : ""}>
              <span class="inline-block rounded-full bg-brand-gold px-4 py-1.5 text-sm font-bold text-brand-blue">{n.edad}</span>
              <h3 class="mt-4 font-display text-3xl font-extrabold text-brand-blue lg:text-4xl">{n.nombre}</h3>
              <p class="mt-3 leading-relaxed text-slate-600">{n.desc}</p>
              <ul class="mt-6 grid gap-3 sm:grid-cols-2">
                {n.puntos.map((punto) => (
                  <li class="flex items-start gap-2.5 text-sm text-slate-700">
                    <Icon name="lucide:circle-check" class="mt-0.5 h-5 w-5 flex-shrink-0 text-brand-teal" />
                    {punto}
                  </li>
                ))}
              </ul>
              <a href="#contacto" class="mt-7 inline-flex items-center gap-2 font-bold text-brand-blue transition-colors hover:text-brand-teal">
                Agenda una visita
                <Icon name="lucide:arrow-right" class="h-4 w-4" />
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Oferta Académica -->
  <section id="oferta" class="relative overflow-hidden bg-brand-blue py-20 text-white lg:py-28">
    <img src="/logos/isotype-light.svg" alt="" aria-hidden="true" class="pointer-events-none absolute top-1/2 -left-40 hidden h-[56rem] w-auto -translate-y-1/2 opacity-[0.06] lg:block" />
    <div class="relative mx-auto grid max-w-7xl gap-12 px-5 lg:grid-cols-2 lg:gap-20 lg:px-8">
      <div class="lg:sticky lg:top-28 lg:self-start">
        <h2 class="font-display text-3xl font-extrabold leading-tight lg:text-4xl">Oferta Académica</h2>
        <p class="mt-5 max-w-md leading-relaxed text-white/70">
          Nuestro currículo combina las mejores prácticas pedagógicas con actividades extracurriculares que enriquecen la experiencia de cada alumno.
        </p>
        <a href="#contacto" class="mt-8 inline-flex items-center gap-2 rounded-full bg-brand-gold px-6 py-3 text-sm font-bold text-brand-blue transition-all hover:brightness-105">
          Inscríbete
          <Icon name="lucide:arrow-right" class="h-4 w-4" />
        </a>
      </div>

      <ul class="divide-y divide-white/10">
        {oferta.map((o) => (
          <li class="flex gap-5 py-6 first:pt-0 last:pb-0">
            <div class="flex h-11 w-11 flex-shrink-0 items-center justify-center rounded-xl bg-brand-gold text-brand-blue">
              <Icon name={o.icon} class="h-5 w-5" />
            </div>
            <div>
              <h3 class="font-display text-lg font-bold text-white">{o.titulo}</h3>
              <p class="mt-1 text-sm leading-relaxed text-white/70">{o.desc}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Comunidad / Instalaciones -->
  <section id="comunidad" class="bg-brand-blue py-20 text-white lg:py-28">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <div class="grid items-center gap-12 lg:grid-cols-2">
        <div>
          <span class="text-sm font-bold uppercase tracking-widest text-brand-gold">Nuestra Comunidad</span>
          <h2 class="mt-3 font-display text-3xl font-extrabold lg:text-4xl">Espacios diseñados para inspirar</h2>
          <p class="mt-5 leading-relaxed text-white/70">
            Cada día en Colegio Manabi es una oportunidad de aprender, crecer y construir amistades que duran toda la vida. Nuestras instalaciones están pensadas para el desarrollo integral de cada alumno.
          </p>
        </div>
        <div class="grid gap-3 sm:grid-cols-2">
          {instalaciones.map((item) => (
            <div class="flex items-start gap-3 rounded-xl bg-white/5 px-4 py-3 ring-1 ring-white/10">
              <svg class="mt-0.5 h-5 w-5 flex-shrink-0 text-brand-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
              <span class="text-sm text-white/80">{item}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Admisiones -->
  <section id="admisiones" class="py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="font-display text-3xl font-extrabold text-brand-blue lg:text-4xl">Proceso de admisión</h2>
        <p class="mt-4 text-slate-600">Nuestro equipo de admisiones está disponible para orientarte en cada paso. Comunícate con nosotros y con gusto te atendemos.</p>
      </div>

      <div id="admisiones-steps" class="relative mt-16">
        <span class="absolute left-[12.5%] right-[12.5%] top-7 hidden h-0.5 bg-brand-blue/15 lg:block" aria-hidden="true"></span>
        <span id="step-line" class="absolute left-[12.5%] top-7 hidden h-0.5 w-0 bg-brand-blue lg:block" aria-hidden="true"></span>
        <div class="grid gap-y-10 sm:grid-cols-2 lg:grid-cols-4">
          {pasos.map((p) => (
            <div class="px-4 text-center">
              <div class="relative z-10 mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-brand-gold font-display text-lg font-extrabold text-brand-blue ring-8 ring-white">
                {p.n}
              </div>
              <h3 class="mt-5 font-display text-lg font-bold text-brand-blue">{p.titulo}</h3>
              <p class="mt-2 text-sm leading-relaxed text-slate-600">{p.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="mt-12">
        <h3 class="font-display text-xl font-bold text-brand-blue">Documentos Requeridos</h3>
        <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {documentos.map((d) => (
            <div class="flex flex-col gap-4 rounded-2xl bg-white p-5 shadow-sm ring-1 ring-slate-100 transition-all hover:-translate-y-0.5 hover:shadow-md hover:ring-brand-teal/40">
              <span class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-brand-teal/10 text-brand-teal">
                <Icon name={d.icon} class="h-5 w-5" />
              </span>
              <div>
                <p class="font-display text-sm font-bold text-brand-blue">{d.label}</p>
                <p class="mt-0.5 text-xs text-slate-500">{d.nota}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- Wide CTA tile spanning below the doc bento -->
        <div class="mt-6 flex flex-col items-center justify-between gap-5 rounded-3xl bg-brand-blue p-6 text-white sm:flex-row sm:gap-8 sm:p-8">
          <div class="text-center sm:text-left">
            <h3 class="font-display text-xl font-extrabold lg:text-2xl">¿Listo para dar el primer paso?</h3>
            <p class="mt-1 text-sm font-medium text-white/80">Nuestro equipo de admisiones te orienta en todo el proceso.</p>
          </div>
          <div class="flex w-full flex-col gap-3 sm:w-auto sm:flex-shrink-0 sm:flex-row">
            <a href="https://wa.me/526462582275" class="inline-flex items-center justify-center gap-2 rounded-full bg-brand-gold py-3 pl-2.5 pr-6 text-sm font-bold text-brand-blue transition-all hover:brightness-110">
              <span class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-[#25D366]">
                <svg class="h-4 w-4 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 0 1 8.413 3.488 11.82 11.82 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.515 5.26l-.999 3.648 3.873-1.015zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
              </span>
              Escríbenos por WhatsApp
            </a>
            <a href="#contacto" class="inline-flex items-center justify-center gap-2 rounded-full bg-white px-6 py-3.5 text-sm font-bold text-brand-blue ring-1 ring-brand-blue/10 transition-all hover:bg-white/70">
              Agenda una visita
              <Icon name="lucide:arrow-right" class="h-4 w-4" />
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    // scroll-scrubbed connector: width tracks how far the stepper has scrolled
    // through the viewport, so it fills going down and empties going back up.
    const wrap = document.getElementById("admisiones-steps");
    const line = document.getElementById("step-line");
    if (wrap && line) {
      let ticking = false;
      const update = () => {
        ticking = false;
        const r = wrap.getBoundingClientRect();
        const vh = window.innerHeight;
        // start filling when the stepper enters low (95% down), full once it reaches 30% up.
        // wider band = slower fill.
        const progress = (vh * 0.95 - r.top) / (vh * 0.65);
        const clamped = Math.max(0, Math.min(1, progress));
        line.style.width = (clamped * 75).toFixed(2) + "%"; // 12.5% → 87.5%
      };
      const onScroll = () => {
        if (!ticking) { ticking = true; requestAnimationFrame(update); }
      };
      update();
      window.addEventListener("scroll", onScroll, { passive: true });
      window.addEventListener("resize", onScroll);
    }
  </script>

  <!-- Contacto -->
  <section id="contacto" class="bg-slate-50 py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-2">
        <div>
          <h2 class="font-display text-3xl font-extrabold text-brand-blue lg:text-4xl">Estamos aquí para ayudarte</h2>
          <p class="mt-5 leading-relaxed text-slate-600">
            Estamos aquí para responder todas tus preguntas. Envíanos un mensaje y nuestro equipo se comunicará contigo a la brevedad.
          </p>

          <div class="mt-8 space-y-4">
            <a href="tel:+526462582275" class="flex items-center gap-4 rounded-2xl bg-white p-4 ring-1 ring-slate-100 transition-all hover:ring-brand-blue/20">
              <span class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-brand-blue/10 text-brand-blue">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25z"/></svg>
              </span>
              <div>
                <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Teléfono</p>
                <p class="font-semibold text-slate-800">+52 (646) 258-2275</p>
              </div>
            </a>

            <a href="mailto:info@colegiomanabi.com" class="flex items-center gap-4 rounded-2xl bg-white p-4 ring-1 ring-slate-100 transition-all hover:ring-brand-blue/20">
              <span class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-brand-blue/10 text-brand-blue">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/></svg>
              </span>
              <div>
                <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Correo electrónico</p>
                <p class="font-semibold text-slate-800">info@colegiomanabi.com</p>
              </div>
            </a>

            <div class="flex items-start gap-4 rounded-2xl bg-white p-4 ring-1 ring-slate-100">
              <span class="inline-flex h-11 w-11 flex-shrink-0 items-center justify-center rounded-xl bg-brand-blue/10 text-brand-blue">
